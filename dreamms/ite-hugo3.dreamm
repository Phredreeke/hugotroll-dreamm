desc[ite-hugo3]:

name = Hugo 3
icon = ite-hugo3.png
machine = pc
rootpath = C:\
launch = $(rootpath)\HUGO.EXE
osenv = dos
fixdivover = true
mips = $(MIPS_P100)
ramkb = 16384
audiohw = sb16
videohw = svga
MAKECFG = false

//
// filesystem
//
mount[]: vpath = C:\; srcpath = $(ifsdeltapath); writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)

//
// Setup
//
VEROPTIONS = false
config[veroptions]:
    condition = $(VEROPTIONS)
    title = Version
    option[dos]: name = Game; priority = 1
    option[win]: name = Sound setup; launch=$(rootpath)\SNDSETUP.EXE; 
end





script[makecfg]:
    condition = MAKECFG
    code = [[[$(CRLF)
    if (!file_exists("$$(rootpath)\\4HUGO.CFG")) 
    { 
    file_save("$$(rootpath)\\4HUGO.CFG", "HEX:87 8D 9E 9D 8A E0 95 EC ED EA EB E8 C7 D8 D9 DA DB DC DD DE F1 FE FF E7 E3 E4 D5 D6 D7 A8 A9 AA AB AC AD AE AF A0 A1 A2 57 A5 A5 A6 EB F9 EB E9 9B F7 93 9E F2 9E 9F 9C B3 B4 B5 B6 B7 88 89 8A A5 A2 A3 BA BF B0 81 82 83 84 85 86 87 98 99 9A 9B 9C 9D 9E 0F 91 91 92 C1 D1 DB D3 B7 2A 47 44 45 42 43 40 6F 60 61 62 63 64 65 66 49 56 57 49 4B 4C 7D 7E 7F 70 71 72 73 74 75 76 77 48 49 4A 67 4D 4D 4E 1B 0F 13 00 06 0A 65 04 69 76 77 74 5B 5C 5D 5E 5F 50 51 52 7D 7A 7B 64 67 18 29 2A 2B 2C 2D 2E 2F 20 21 22 23 24 25 26 EF 38 39 3A 68 68 74 79 1F 7A 1F 1C 1D 1A 1B 18 37 08 09 0A 0B 0C 0D 0E 21 2E 2F 33 33 34 05 06 07 18 19 1A 1B 1C 1D 1E 1F 10 11 12 77 14 15 16 81 8D 86 81 8D E0 87 EC ED EA EB E8 C7 D8 D9 DA DB DC DD DE F1 FE FF E7 E3 E4 D5 D6 D7 A8 A9 AA AB AC AD AE AF A0 A1 A2 57 A5 A5 A6 E9 F1 FC F6 E8 9C F6 90 9F FD 9F 9C B3 B4 B5 B6 B7 88 89 8A A5 A2 A3 BA BF B0 81 82 83 84 85 86 87 98 99 9A 9B 9C 9D 9E 0F 91 91 92 D2 DA D1 D3 C5 3B 49 27 45 42 43 40 6F 60 61 62 63 64 65 66 49 56 57 49 4B 4C 7D 7E 7F 70 71 72 73 74 75 76 77 48 49 4A 67 4D 4D 4E 1B 0F 13 00 06 0A 65 04 69 76 77 74 5B 5C 5D 5E 5F 50 51 52 7D 7A 7B 64 67 18 29 2A 2B 2C 2D 2E 2F 20 21 22 23 24 25 26 EF 38 39 3A 68 68 74 79 1F 7A 1F 1C 1D 1A 1B 18 37 08 09 0A 0B 0C 0D 0E 21 2E 2F 33 33 34 05 06 07 18 19 1A 1B 1C 1D 1E 1F 10 11 12 77 14 15 16 81 8D 86 81 8D E0 87 EC ED EA EB E8 C7 D8 D9 DA DB DC DD DE F1 FE FF E7 E3 E4 D5 D6 D7 A8 A9 AA AB AC AD AE AF A0 A1 A2 57 A5 A5 A6 F5 FD F7 FF 9B FE 93 90 91 9E 9F 9C B3 B4 B5 B6 B7 88 89 8A A5 A2 A3 BA BF B0 81 82 83 84 85 86 87 98 99 9A 9B 9C 9D 9E 0F 91 91 92 C7 DB C7 D4 D2 26 49 28 45 42 43 40 6F 60 61 62 63 64 65 66 49 56 57 49 4B 4C 7D 7E 7F 70 71 72 73 74 75 76 77 48 49 4A 67 4D 4D 4E 03 01 14 11 17 64 15 68 67 16 77 74 5B 5C 5D 5E 5F 50 51 52 7D 7A 7B 64 67 18 29 2A 2B 2C 2D 2E 2F 20 21 22 23 24 25 26 EF 38 39 3A 70 75 70 1E 79 1E 1F 1C 1D 1A 1B 18 37 08 09 0A 0B 0C 0D 0E 21 2E 2F 33 33 34 05 06 07 18 19 1A 1B 1C 1D 1